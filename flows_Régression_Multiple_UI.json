    {
        "id": "106e9a82b987a12a",
        "type": "function",
        "z": "95e8e68d05a6816b",
        "name": "Récupérer et prédire",
        "func": "const model = global.get('model');\nif (!model) {\n    msg.payload = 'Erreur : modèle non entraîné !';\n    return msg;\n}\n\nconst superficie = flow.get('superficie') || 0;\nconst etage      = flow.get('etage')      || 0;\nconst age        = flow.get('age')        || 0;\n\nconst result = model.predict([superficie, etage, age]);\nconst prix = Math.round(result[0]);\n\nmsg.payload = 'Prix prédit : ' + prix + ' k€';\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 500,
        "y": 460,
        "wires": [
