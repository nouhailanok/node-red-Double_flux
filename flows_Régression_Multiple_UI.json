        "type": "function",
        "z": "95e8e68d05a6816b",
        "name": "Entraînement",
        "func": "const X = [\n    [50,  1, 10],\n    [80,  2, 5 ],\n    [120, 3, 2 ],\n    [60,  1, 20],\n    [100, 4, 8 ],\n    [90,  2, 15],\n    [70,  3, 3 ]\n];\nconst Y = [\n    [150],\n    [220],\n    [350],\n    [160],\n    [300],\n    [250],\n    [210]\n];\nconst MLR = global.get('mlr');\nconst model = new MLR(X, Y);\nglobal.set('model', model);\nmsg.payload = 'Modèle entraîné ✅';\nreturn msg;",
        "outputs": 1,
        "x": 460,
        "y": 100,
