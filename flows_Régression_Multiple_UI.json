        "name": "Stocker valeurs",
        "func": "// On mémorise chaque valeur selon son topic\nflow.set(msg.topic, msg.payload);\n\nconst superficie = flow.get('superficie') || 0;\nconst etage      = flow.get('etage')      || 0;\nconst age        = flow.get('age')        || 0;\n\nmsg.payload = { superficie, etage, age };\nreturn msg;",
