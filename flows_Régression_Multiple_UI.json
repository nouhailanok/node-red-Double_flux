                "8904f6add250c98b"
            ]
        ]
    },
    {
        "id": "aca75f41274ea03e",
        "type": "function",
        "z": "95e8e68d05a6816b",
        "name": "Prédiction auto",
        "func": "const model = global.get('model');\nif (!model) return null;\n\nconst { superficie, etage, age } = msg.payload;\nconst result = model.predict([superficie, etage, age]);\nconst prix = Math.round(result[0]);\n\nmsg.payload ='Prix prédit : ' + prix + ' k€';\nreturn msg;",
