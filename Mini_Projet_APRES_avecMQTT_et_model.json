    {
        "id": "36d86c8d85c9e738",
        "type": "function",
        "z": "23ad1042661365f3",
        "name": "Simulation GPU / Temp / Fan",
        "func": "context.temp = context.temp || 45;\ncontext.fan = context.fan || 1200;\ncontext.gpu = context.gpu || 60;\n\nlet variation = Math.random() * 10 - 5;\nlet gpu = context.gpu + variation;\ngpu = Math.max(30, Math.min(95, gpu));\n\n// ✅ Température limitée entre 40 et 90°C\nlet temp = context.temp + (gpu - 50) * 0.03;\ntemp = Math.max(40, Math.min(90, temp));\n\nlet fan = context.fan;\nif (temp > 75) { fan += 200; } else if (temp < 65) { fan -= 150; }\nfan = Math.max(800, Math.min(4000, fan));\n\ncontext.temp = temp;\ncontext.fan = fan;\ncontext.gpu = gpu;\n\nmsg.payload = {\n    gpu: Math.round(gpu),\n    temperature: Math.round(temp),\n    fan: Math.round(fan),\n    time: new Date().toLocaleTimeString()\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 840,
        "y": 280,
        "wires": [
            [
                "7c59bf4e3c2070f6"
            ]
        ]
    },
