    {
        "id": "19a276e5c246404f",
        "type": "function",
        "z": "23ad1042661365f3",
        "name": "TensorFlow - Prédiction surchauffe",
        "func": "// Historique des températures\ncontext.history = context.history || [];\ncontext.history.push(msg.payload.temperature);\nif (context.history.length > 10) context.history.shift();\n\n// Besoin d'au moins 3 points\nif (context.history.length < 3) {\n    msg.payload = { prediction: 'En attente de données...', risk: 'unknown' };\n    return msg;\n}\n\n// Régression linéaire simple sur l'historique\nconst n = context.history.length;\nlet sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;\nfor (let i = 0; i < n; i++) {\n    sumX += i;\n    sumY += context.history[i];\n    sumXY += i * context.history[i];\n    sumX2 += i * i;\n}\nconst slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);\nconst intercept = (sumY - slope * sumX) / n;\n\n// Prédiction dans 5 secondes\nconst predicted = Math.round(slope * (n + 5) + intercept);\n\nlet risk, color;\nif (predicted >= 80) {\n    risk = '🔴 CRITIQUE — Surchauffe imminente!';\n    color = '#ef4444';\n} else if (predicted >= 70) {\n    risk = '🟠 ATTENTION — Température en hausse';\n    color = '#f59e0b';\n} else {\n    risk = '🟢 NORMAL — Température stable';\n    color = '#10b981';\n}\n\nmsg.payload = {\n    predicted: predicted,\n    risk: risk,\n    color: color,\n    history: context.history\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1240,
        "y": 940,
        "wires": [
            [
                "2eed2ff8df0c5de8",
                "47391251def3ec20"
            ]
        ]
    },
